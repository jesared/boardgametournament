generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ScoringType {
  ranking
  raw
}

enum UserRole {
  admin
  organizer
  viewer
}

model TournamentSession {
  id        String   @id @default(cuid())
  name      String
  date      DateTime
  createdAt DateTime @default(now())

  players Player[]
  rounds  Round[]
  shares  SessionShareToken[]

  @@map("Session")
}

model Player {
  id        String   @id @default(cuid())
  name      String
  sessionId String

  session           TournamentSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tableParticipants TableParticipant[]

  @@index([sessionId])
}

model Game {
  id          String      @id @default(cuid())
  name        String
  minPlayers  Int
  maxPlayers  Int
  duration    Int
  scoringType ScoringType
  rules       String?

  tables Table[]
}

model Round {
  id        String  @id @default(cuid())
  sessionId String
  order     Int
  validatedAt DateTime?
  createdAt DateTime @default(now())

  session TournamentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  tables  Table[]

  @@unique([sessionId, order])
  @@index([sessionId])
}

model Table {
  id      String @id @default(cuid())
  roundId String
  gameId  String

  round        Round             @relation(fields: [roundId], references: [id], onDelete: Cascade)
  game         Game              @relation(fields: [gameId], references: [id])
  participants TableParticipant[]

  @@index([roundId])
}

model TableParticipant {
  id       String  @id @default(cuid())
  tableId  String
  playerId String
  position Int?
  score    Int?

  table  Table  @relation(fields: [tableId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([tableId])
  @@index([playerId])
}

model ChangeLog {
  id         String   @id @default(cuid())
  sessionId  String
  action     String
  entityType String
  entityId   String?
  message    String?
  createdAt  DateTime @default(now())

  @@index([sessionId])
  @@index([createdAt])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  role          UserRole  @default(organizer)
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?

  accounts Account[]
  sessions Session[]
  authLogs AuthLog[]
  adminLogs AdminLog[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("AuthSession")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model AuthLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  provider  String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model AdminLog {
  id         String   @id @default(cuid())
  adminId    String?
  action     String
  entityType String?
  entityId   String?
  message    String?
  createdAt  DateTime @default(now())

  admin User? @relation(fields: [adminId], references: [id], onDelete: SetNull)

  @@index([adminId])
  @@index([createdAt])
}

model SessionShareToken {
  id        String   @id @default(cuid())
  sessionId String
  token     String   @unique
  createdAt DateTime @default(now())
  createdBy String?

  session TournamentSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}
